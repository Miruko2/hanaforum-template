# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.vercel

# ⚠️ 敏感凭证：绝对不能进仓库
supabase_apikey.txt
*.keystore

# ⚠️ 敏感词种子 SQL：含政治敏感词，由 scripts/seed-sensitive-words.mjs 生成，绝不进仓库
scripts/seed-sensitive-words.generated.sql

# 本地构建/临时产物
/out/
tsconfig.tsbuildinfo

# Capacitor 静态构建过程中临时挪走 app/api 的备份位置
# 正常情况下 scripts/build-capacitor.js 的 finally 块会恢复，目录不会存在
# 但万一中断 / 异常残留，这条规则避免误 commit
/_api_backup/

# Android APK 产物：体积大、每次发版重生成，不进 git。
# 当前线上分发走 Supabase Storage 的 downloads bucket，public/downloads/ 仅是本地兜底/备份
public/downloads/*.apk

# 切换包管理器（pnpm → npm）时改名出来的临时目录，等你方便时手动 rm 掉
/node_modules_old/

# capacitor / next 构建过程中重定向输出的调试日志
build.log

# 测试输出日志
jest-out.log

# 本地设计参考图（cankao* 系列，临时素材，不入库）
/cankao*.png
/cankao*.jpg
/cankao*.jpeg
/cankao*.webp

# 本地 CDN 调试笔记
/cdn-debug-summary.md

# 本地记忆库（AI 辅助开发笔记，不入库）
/memory-bank/
