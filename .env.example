# ============================================================
# 萤火虫之国 — 环境变量示例
# ============================================================
# 复制本文件为 .env.local 并填入你自己的值。
# .env.local 已被 .gitignore 忽略，不会被提交。
#
# ⚠️ 绝不要把真实的密钥填进本文件（.env.example 会被提交到 git）。
#     本文件只作占位/说明用途。

# ─── Supabase ───────────────────────────────────────────────
# 在 https://supabase.com/dashboard/project/_/settings/api 获取
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的_anon_public_key
# service_role key：服务端用，绝不暴露到前端（无 NEXT_PUBLIC_ 前缀）
SUPABASE_SERVICE_ROLE_KEY=你的_service_role_key

# ─── AI（DeepSeek）──────────────────────────────────────────
# 在 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=sk-你的_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 私信 AI（萌萌子）可独立配置模型；不配则复用上面的 DeepSeek
DM_AI_API_KEY=
DM_AI_BASE_URL=
DM_AI_MODEL=deepseek-chat

# ─── 联网搜索（Tavily，可选）──────────────────────────────
# 在 https://tavily.com/ 获取；不配则 AI 不联网
TAVILY_API_KEY=

# ─── 图片配图（Unsplash，萌萌子 agent 发帖用，可选）──────────
# 在 https://unsplash.com/oauth/applications 申请，免费
UNSPLASH_ACCESS_KEY=

# ─── 萌萌子 Agent（自动发帖/留言/回复）──────────────────────
# CF Worker Cron 戳 /api/mengmegzi-tick 时带的密钥（与 wrangler secret 一致）
MENGMEGZI_CRON_SECRET=随机生成一串密钥

# ─── AI 账号 UUID（建号后填入）─────────────────────────────
# 见 scripts/create-mengmegzi-account.mjs 建号流程
HANAKO_USER_ID=你的_hanako_账号_uuid
MENGMEGZI_USER_ID=你的_mengmegzi_账号_uuid

# ─── 管理员用户 ID（逗号分隔，支持多个）─────────────────────
# 在 Supabase Dashboard → Auth → Users 查看你的用户 UUID
# 配置后这些用户在前端会被识别为管理员（仍需在 admin_users 表中登记）
NEXT_PUBLIC_ADMIN_USER_IDS=你的管理员用户uuid
# 多个用逗号：NEXT_PUBLIC_ADMIN_USER_IDS=uuid1,uuid2,uuid3

# ─── 站点 URL（SEO / 邮件 / 分享用）────────────────────────
# 生产填你的正式域名，本地开发填 http://localhost:3000
SITE_URL=https://your-domain.com

# ─── Presence WebSocket（Cloudflare Worker，可选）──────────
# 不配则实时在线状态静默降级（永远空）
NEXT_PUBLIC_PRESENCE_WS_URL=wss://presence.your-domain.com/ws

# ─── 图片 CDN（Cloudflare R2 自托管，可选）─────────────────
# 不配则前端直连 Supabase Storage
NEXT_PUBLIC_IMG_CDN_BASE=https://img.your-domain.com

# ─── 抠像模型 CDN（自托管 ONNX 模型，可选）─────────────────
# 不配则回退 HuggingFace 原站（国内需代理）
NEXT_PUBLIC_MATTE_MODEL_CDN=https://models.your-domain.com

# ─── 邮件发送（Resend + Brevo 多通道，可选）────────────────
# 在 https://resend.com/ 获取
RESEND_API_KEY=
RESEND_FROM=你的发信地址@your-domain.com
# Brevo SMTP 兜底（JSON 数组，见 scripts/test-brevo-smtp.mjs）
EMAIL_SMTP_FALLBACKS=
# 关闭 Resend 时填 1
EMAIL_DISABLE_RESEND=

# ─── Cloudflare（platform-quota 面板用，可选）──────────────
CF_API_TOKEN=
CF_ACCOUNT_ID=
# Brevo 配额查询用
BREVO_API_KEY=

# ─── Capacitor APK 构建用（不构建 APK 可忽略）──────────────
# 构建安卓 APK 时注入线上 origin，让 WebView fetch 走绝对路径
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com
